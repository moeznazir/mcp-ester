# Remote Xano MCP (Streamable HTTP / SSE)
XANO_MCP_URL=https://your-workspace.example/x2/mcp/.../mcp/stream
# Sent as Bearer by default; set XANO_AUTH_MODE=apikey for X-API-Key header
XANO_API_KEY=

GEMINI_API_KEY=

# Transport: streamable (default for HTTPS MCP), sse, stdio
MCP_TRANSPORT=streamable

# stdio only — local MCP server command (ignored unless MCP_TRANSPORT=stdio)
# MCP_STDIO_COMMAND=npx
# MCP_STDIO_ARGS=["-y","@some/mcp-server"]

# Defaults to gemini-3-flash-preview if unset (override if your key supports a different id)
# GEMINI_MODEL=gemini-3-flash-preview
