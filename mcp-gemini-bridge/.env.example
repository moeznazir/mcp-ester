XANO_MCP_URL=https://your-workspace.example/x2/mcp/.../mcp/stream
GEMINI_API_KEY=

# Optional static MCP auth (API key or Bearer) when not using password login
# XANO_API_KEY=
# XANO_AUTH_MODE=bearer

# Password login for protected Xano APIs (Bearer injected on every MCP HTTP request)
# XANO_AUTH_ENDPOINT=https://your-workspace.example/api/auth/login
# XANO_USERNAME=
# XANO_PASSWORD=
# TOKEN_EXPIRY_SECONDS=3600

# Optional refresh (short-lived access + refresh token from login response)
# XANO_REFRESH_ENDPOINT=https://your-workspace.example/api/auth/refresh
# XANO_REFRESH_BODY={"refresh_token":"{{REFRESH_TOKEN}}"}

# Optional: custom login JSON (defaults to { "email": XANO_USERNAME, "password": XANO_PASSWORD })
# XANO_AUTH_LOGIN_BODY={"email":"{{USERNAME}}","password":"{{PASSWORD}}"}
# XANO_AUTH_USER_FIELD=email

MCP_TRANSPORT=streamable
# Set to 1 to log outgoing MCP request header *names* and whether Authorization is set (never logs token values)
# MCP_LOG_AUTH_HEADERS=1
# UNSAFE: prints full access token to stderr when set — use only briefly to verify MCP headers, then unset
# MCP_DEBUG_PRINT_ACCESS_TOKEN=1
# GEMINI_MODEL=gemini-3-flash-preview
