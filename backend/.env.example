ANTHROPIC_API_KEY=your_anthropic_key_here
GEMINI_API_KEY=your_gemini_key_here
# Free tier has low per-day limits per model; if you hit 429 quota errors, change model or enable billing.
# Defaults to gemini-3-flash-preview in code if unset — see https://ai.google.dev/gemini-api/docs/models
# GEMINI_MODEL=gemini-2.0-flash
XANO_MCP_URL=https://your-workspace.example/mcp
# Browser user login (optional). Defaults to DealDetails MCP auth/login; override with:
# USER_AUTH_LOGIN_URL=https://api.dealdetails.com/api:e_5dMhMN:mcp-v1/auth/login
# Static MCP / Xano API bearer (optional if using password login below).
# When XANO_AUTH_* is set, the login access token is sent as this same Bearer on every MCP call (authenticates tool APIs on Xano).
# XANO_MCP_TOKEN=your_xano_bearer_token

# Password login — token from this flow is used as the MCP Authorization Bearer (same role as XANO_MCP_TOKEN above)
# XANO_AUTH_ENDPOINT=https://your-workspace.example/api/auth/login
# XANO_USERNAME=
# XANO_PASSWORD=
# TOKEN_EXPIRY_SECONDS=3600
# Optional: custom JSON body with {{USERNAME}} {{PASSWORD}}
# XANO_AUTH_LOGIN_BODY={"email":"{{USERNAME}}","password":"{{PASSWORD}}"}
# XANO_AUTH_USER_FIELD=email
# Optional refresh
# XANO_REFRESH_ENDPOINT=
# XANO_REFRESH_BODY={"refresh_token":"{{REFRESH_TOKEN}}"}
# UNSAFE: logs full MCP Bearer (XANO_MCP_TOKEN) to server console — debugging only
# MCP_DEBUG_PRINT_ACCESS_TOKEN=1
# UNSAFE: allows browser console to receive MCP Bearer via ?debugMcp=1 or localStorage DEBUG_MCP_BROWSER=1
# DEBUG_BROWSER_MCP_TOKEN=1
PORT=3000
